# Copie ce fichier en .env et remplis les valeurs

# Port du serveur (Railway le définit automatiquement)
PORT=3001

# URL du frontend (Vercel te donnera cette URL après déploiement)
FRONTEND_URL=https://ton-app.vercel.app

# Clé secrète pour signer les JWT — génère une chaîne aléatoire longue
# Exemple : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
